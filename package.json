{
  "name": "threads-manager",
  "version": "1.1.5",
  "description": "Threads multi-account manager for Mac",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"npm run electron:dev\"",
    "electron:dev": "wait-on http://localhost:5173 && wait-on dist-electron/main.js && cross-env NODE_ENV=development electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder --config electron-builder.prod.yml",
    "dist:dev": "npm run build && electron-builder --config electron-builder.dev.yml",
    "dist:prod": "npm run build && electron-builder --config electron-builder.prod.yml",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@supabase/supabase-js": "^2.99.2",
    "better-sqlite3": "^9.4.3",
    "discord.js": "^14.25.1",
    "electron-log": "^5.4.3",
    "electron-store": "^7.0.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "otpauth": "^9.5.0",
    "papaparse": "^5.5.3",
    "playwright": "^1.43.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.0",
    "wanakana": "^5.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.12.7",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vite-plugin-electron": "^0.28.6",
    "wait-on": "^7.2.0"
  }
}
